/target

# Runtime artifacts (generated on first run)
/bbs.toml
/bbs.db
/bbs.db-journal
/bbs.db-wal
/bbs.db-shm
/host_key
/host_key.pub
# Web TLS: the auto-generated self-signed cert/key ([web] tls_cert/tls_key)
# and the ACME account key + issued certs. Never commit these.
/web-cert.pem
/web-key.pem
/acme-cache/
# File-area storage (default [files].storage_dir)
/files/

# Editor swap files
*.swp
*.swo
*.swn
.*.swp

# Door game save data (runtime)
loid-saves/
doors/loid-data/
